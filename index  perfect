  <!-- --- GRAPHICS RENDERING PIPELINE --- -->
  <script type="module">
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

    // 1. ENVIRONMENT STAGING CONFIGURATION
    const canvas = document.querySelector('#webgl-canvas');
    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog('#040406', 15, 55); // Gentle linear studio fog to prevent black fade
    // Background removed to allow HTML transparent layers behind canvas

    const camera = new THREE.PerspectiveCamera(38, window.innerWidth / window.innerHeight, 0.05, 100);

    // Initial Camera Target Arrays
    let cameraPosition = new THREE.Vector3(0, 1.4, 7.8);
    let cameraTarget = new THREE.Vector3(0, 0.2, 0);
    camera.position.copy(cameraPosition);

    const renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5)); // Cap at 1.5 for perf

    // Soft Cinematic Shading Optimizations
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.0;

    // 2. SOFT FALL-OFF SHOWROOM LIGHTING RIG (Crisp whites by default for realism)
    const backgroundFill = new THREE.AmbientLight('#ffffff', 0.15); // Lifted ambient shadows
    scene.add(backgroundFill);

    const zenithHighlight = new THREE.DirectionalLight('#ffffff', 0.15);
    zenithHighlight.position.set(0, 12, 0);
    scene.add(zenithHighlight);

    const zenithHighlight1 = new THREE.DirectionalLight('#ffffff', 0.60);
    zenithHighlight1.position.set(3, 12, 0);
    scene.add(zenithHighlight1);

    const zenithHighlight2 = new THREE.DirectionalLight('#ffffff', 0.60);
    zenithHighlight2.position.set(-3, 12, 0);
    scene.add(zenithHighlight2);

    // Back side zenith highlights
    const zenithHighlightBack = new THREE.DirectionalLight('#ffffff', 0);
    zenithHighlightBack.position.set(0, 2, 4);
    scene.add(zenithHighlightBack);

    const zenithHighlight1Back = new THREE.DirectionalLight('#ffffff', 0.50);
    zenithHighlight1Back.position.set(3, 2, 4);
    scene.add(zenithHighlight1Back);

    const zenithHighlight2Back = new THREE.DirectionalLight('#ffffff', 0.50);
    zenithHighlight2Back.position.set(-3, 2, 4);
    scene.add(zenithHighlight2Back);

    // Right Side Key: Soft White SpotLight with maximum blur fallback edges
    const tealSpotKey = new THREE.SpotLight('#ffffff', 10.0, 40, Math.PI / 4, 1.0, 1.1);
    tealSpotKey.position.set(7, 6, 4);
    tealSpotKey.castShadow = true;
    tealSpotKey.shadow.mapSize.width = 2048;
    tealSpotKey.shadow.mapSize.height = 2048;
    tealSpotKey.shadow.bias = -0.00004;
    scene.add(tealSpotKey);

    // Left Side Key: Soft White SpotLight with maximum blur fallback edges
    const orangeSpotKey = new THREE.SpotLight('#ffffff', 10.0, 40, Math.PI / 4, 1.0, 1.1);
    orangeSpotKey.position.set(-7, 6, 4);
    orangeSpotKey.castShadow = true;
    orangeSpotKey.shadow.mapSize.width = 2048;
    orangeSpotKey.shadow.mapSize.height = 2048;
    orangeSpotKey.shadow.bias = -0.00004;
    scene.add(orangeSpotKey);

    // Right Side Rim: Soft White SpotLight (Focuses on roofline and rear shoulder contours)
    const tealSpotRim = new THREE.SpotLight('#ffffff', 10.0, 40, Math.PI / 4.5, 0.8, 1.1);
    tealSpotRim.position.set(6, 7.5, -7);
    tealSpotRim.castShadow = false;
    tealSpotRim.shadow.bias = -0.00004;
    scene.add(tealSpotRim);

    // Left Side Rim: Soft White SpotLight (Focuses on roofline and rear shoulder contours)
    const orangeSpotRim = new THREE.SpotLight('#ffffff', 10.0, 40, Math.PI / 4.5, 0.8, 1.1);
    orangeSpotRim.position.set(-6, 7.5, -7);
    orangeSpotRim.castShadow = false;
    orangeSpotRim.shadow.bias = -0.00004;
    scene.add(orangeSpotRim);

    // Under-chassis volumetric highlight clusters for surface ground bounce effects (Dimmed to prevent washing out contact shadows)
    const underTealFill = new THREE.PointLight('#ffffff', 0.8, 9, 1.8);
    underTealFill.position.set(3.5, 0.5, 1);
    scene.add(underTealFill);

    const underOrangeFill = new THREE.PointLight('#ffffff', 0.8, 9, 1.8);
    underOrangeFill.position.set(-3.5, 0.5, 1);
    scene.add(underOrangeFill);

    // Top-Front volumetric highlight clusters for surface ground bounce effects
    const topFrontTealFill = new THREE.PointLight('#ffffff', 6.0, 9, 1.8);
    topFrontTealFill.position.set(1.5, 5.5, 1.75);
    scene.add(topFrontTealFill);

    const topFrontOrangeFill = new THREE.PointLight('#ffffff', 6.0, 9, 1.8);
    topFrontOrangeFill.position.set(-1.5, 5.5, 1.75);
    scene.add(topFrontOrangeFill);


    // Under-chassis volumetric highlight clusters for surface ground bounce effects (Dimmed to prevent washing out contact shadows)
    const underTealFillback = new THREE.PointLight('#ffffff', 0.8, 9, 1.8);
    underTealFillback.position.set(3.5, 0.5, -4);
    scene.add(underTealFillback);

    const underOrangeFillback = new THREE.PointLight('#ffffff', 0.8, 9, 1.8);
    underOrangeFillback.position.set(-3.5, 0.5, -4);
    scene.add(underOrangeFillback);

    // Front Spotlight for direct grille and hood illumination (Distance increased from 10 to 18 to prevent shadow camera frustum clipping)
    const frontSpotLight = new THREE.SpotLight(0xffffff, 25.0, 18, Math.PI / 5, 0.8, 1.2);
    frontSpotLight.position.set(0, 2, 10);
    frontSpotLight.castShadow = true;
    frontSpotLight.shadow.mapSize.width = 2048;
    frontSpotLight.shadow.mapSize.height = 2048;
    frontSpotLight.shadow.bias = -0.00004;
    scene.add(frontSpotLight);

    const rearSpotLight = new THREE.SpotLight(0xffffff, 2.0, 10, Math.PI / 5, 0.5, 1.2);
    rearSpotLight.position.set(0, 1, -5);
    rearSpotLight.castShadow = true;
    rearSpotLight.shadow.mapSize.width = 2048;
    rearSpotLight.shadow.mapSize.height = 2048;
    rearSpotLight.shadow.bias = -0.00004;
    scene.add(rearSpotLight);
    scene.add(rearSpotLight.target);

    // Rear Spotlights (Distance increased from 5 to 12 to prevent shadow camera frustum clipping)
    const rearSpotLight1 = new THREE.SpotLight(0xffffff, 12.0, 12, Math.PI / 5, 0.8, 1.2);
    rearSpotLight1.position.set(1, 2, -5);
    rearSpotLight1.castShadow = true;
    rearSpotLight1.shadow.mapSize.width = 2048;
    rearSpotLight1.shadow.mapSize.height = 2048;
    rearSpotLight1.shadow.bias = -0.00004;
    scene.add(rearSpotLight1);
    scene.add(rearSpotLight1.target);

    const rearSpotLight2 = new THREE.SpotLight(0xffffff, 12.0, 12, Math.PI / 5, 0.8, 1.2);
    rearSpotLight2.position.set(-1, 2, -5);
    rearSpotLight2.castShadow = true;
    rearSpotLight2.shadow.mapSize.width = 2048;
    rearSpotLight2.shadow.mapSize.height = 2048;
    rearSpotLight2.shadow.bias = -0.00004;
    scene.add(rearSpotLight2);
    scene.add(rearSpotLight2.target);

    // Rear Bottom Spotlights (Dimmed from 8.0 to 2.0 to prevent shadow washout)
    const rearSpotLightbottom1 = new THREE.SpotLight(0xffffff, 2.0, 5, Math.PI / 2, 0.5, 0.5);
    rearSpotLightbottom1.position.set(1, 0.1, -3.8);
    rearSpotLightbottom1.target.position.set(0, 1.5, -2);
    rearSpotLightbottom1.castShadow = false;
    rearSpotLightbottom1.shadow.bias = -0.00004;
    rearSpotLightbottom1.target.updateMatrixWorld();
    scene.add(rearSpotLightbottom1);

    const rearSpotLightbottom2 = new THREE.SpotLight(0xffffff, 2.0, 5, Math.PI / 2, 0.5, 0.5);
    rearSpotLightbottom2.position.set(-1, 0.1, -3.8);
    rearSpotLightbottom2.target.position.set(0, 1.5, -2);
    rearSpotLightbottom2.castShadow = false;
    rearSpotLightbottom2.shadow.bias = -0.00004;
    rearSpotLightbottom2.target.updateMatrixWorld();
    scene.add(rearSpotLightbottom2);

    // --- 2. Lighting & Environment ---

    const hemiLight = new THREE.HemisphereLight(0xffffff, 0x444444, 0);
    scene.add(hemiLight);

    // Top directional light: Enabled shadows for deep, sharp, and physically realistic contact shadows on the floor
    const topLight = new THREE.DirectionalLight(0xffffff, 1.20);
    topLight.position.set(0, 5, 0);
    topLight.castShadow = true;
    topLight.shadow.mapSize.width = 2048;
    topLight.shadow.mapSize.height = 2048;
