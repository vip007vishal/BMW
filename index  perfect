        this.padFilterNode = this.audioCtx.createBiquadFilter();
        this.padFilterNode.type = 'lowpass';
        this.padFilterNode.frequency.setValueAtTime(150, this.audioCtx.currentTime);
        this.padFilterNode.Q.setValueAtTime(1.0, this.audioCtx.currentTime);

        this.delayL = this.audioCtx.createDelay(1.0);
        this.delayR = this.audioCtx.createDelay(1.0);
        this.feedbackL = this.audioCtx.createGain();
        this.feedbackR = this.audioCtx.createGain();
        this.panDelayL = this.audioCtx.createStereoPanner ? this.audioCtx.createStereoPanner() : null;
        this.panDelayR = this.audioCtx.createStereoPanner ? this.audioCtx.createStereoPanner() : null;

        this.delayL.delayTime.setValueAtTime(0.38, this.audioCtx.currentTime);
        this.delayR.delayTime.setValueAtTime(0.55, this.audioCtx.currentTime);
        this.feedbackL.gain.setValueAtTime(0.35, this.audioCtx.currentTime);
        this.feedbackR.gain.setValueAtTime(0.35, this.audioCtx.currentTime);
        if (this.panDelayL) this.panDelayL.pan.setValueAtTime(-0.7, this.audioCtx.currentTime);
        if (this.panDelayR) this.panDelayR.pan.setValueAtTime(0.7, this.audioCtx.currentTime);

        this.bassFilterNode = this.audioCtx.createBiquadFilter();
        this.bassFilterNode.type = 'lowpass';
        this.bassFilterNode.frequency.setValueAtTime(130, this.audioCtx.currentTime);
        this.bassFilterNode.Q.setValueAtTime(1.0, this.audioCtx.currentTime);

        this.bassDelayNode = this.audioCtx.createDelay(0.1);
        this.bassDelayNode.delayTime.setValueAtTime(0.024, this.audioCtx.currentTime);

        this.bassPanL = this.audioCtx.createStereoPanner ? this.audioCtx.createStereoPanner() : null;
        this.bassPanR = this.audioCtx.createStereoPanner ? this.audioCtx.createStereoPanner() : null;
        if (this.bassPanL) this.bassPanL.pan.setValueAtTime(-0.80, this.audioCtx.currentTime);
        if (this.bassPanR) this.bassPanR.pan.setValueAtTime(0.80, this.audioCtx.currentTime);

        this.mainGain = this.audioCtx.createGain();
        this.mainGain.gain.setValueAtTime(0.0, this.audioCtx.currentTime);

        this.analyser = this.audioCtx.createAnalyser();
        this.analyser.fftSize = 64;

        this.filterNode.connect(this.delayL);
        this.delayL.connect(this.feedbackL);
        this.feedbackL.connect(this.delayR);
        this.delayR.connect(this.feedbackR);
        this.feedbackR.connect(this.delayL);

        this.filterNode.connect(this.mainGain);

        if (this.panDelayL) {
          this.delayL.connect(this.panDelayL);
          this.panDelayL.connect(this.mainGain);
        } else {
          this.delayL.connect(this.mainGain);
        }
        if (this.panDelayR) {
          this.delayR.connect(this.panDelayR);
          this.panDelayR.connect(this.mainGain);
        } else {
          this.delayR.connect(this.mainGain);
        }

        this.padFilterNode.connect(this.mainGain);

        this.mainGain.connect(this.analyser);
        this.analyser.connect(this.audioCtx.destination);
      }

      start() {
        if (this.isPlaying) return;
        if (!this.audioCtx) this.init();
        if (this.audioCtx.state === 'suspended') this.audioCtx.resume();

        this.isPlaying = true;
        this.mainGain.gain.cancelScheduledValues(this.audioCtx.currentTime);
        this.mainGain.gain.setValueAtTime(0.0, this.audioCtx.currentTime);

        const targetGain = (engineSound.isPlaying || exhaustSound.isPlaying) ? 0.03 : 0.28;
        this.mainGain.gain.linearRampToValueAtTime(targetGain, this.audioCtx.currentTime + 2.5);

        this.playNextChord();
      }

      fadeTo(targetGain, duration = 1.0) {
        if (!this.isPlaying || !this.audioCtx || !this.mainGain) return;
        const now = this.audioCtx.currentTime;
        this.mainGain.gain.cancelScheduledValues(now);
        this.mainGain.gain.setValueAtTime(this.mainGain.gain.value, now);
        this.mainGain.gain.linearRampToValueAtTime(targetGain, now + duration);
      }

      playNextChord() {
        if (!this.isPlaying) return;

        const now = this.audioCtx.currentTime;
        const chord = this.chords[this.currentChordIdx];
        const duration = 6.0;

        const chordOscillators = [];
        const chordGains = [];

        // Drone
        const padOsc = this.audioCtx.createOscillator();
        padOsc.type = 'triangle';
        padOsc.frequency.setValueAtTime(chord.root, now);

        const vibratoLfo = this.audioCtx.createOscillator();
        vibratoLfo.type = 'sine';
        vibratoLfo.frequency.setValueAtTime(0.25, now);
        const vibratoGain = this.audioCtx.createGain();
        vibratoGain.gain.setValueAtTime(1.5, now);

        vibratoLfo.connect(vibratoGain);
        vibratoGain.connect(padOsc.frequency);

        const padGain = this.audioCtx.createGain();
        padGain.gain.setValueAtTime(0.0, now);
        padGain.gain.linearRampToValueAtTime(0.035, now + 2.0);
        padGain.gain.setValueAtTime(0.035, now + duration - 2.5);
