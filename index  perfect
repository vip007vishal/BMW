        // Determine if all targets match the same scheme to sync the global 'all' state
        if (activeSchemes.key === activeSchemes.rim &&
          activeSchemes.rim === activeSchemes.under &&
          activeSchemes.under === activeSchemes.ceiling) {
          activeSchemes.all = activeSchemes.key;
