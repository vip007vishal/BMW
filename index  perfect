        // Peaceful showroom chord progression with root drone configurations (Fmaj9, Cmaj9, G6/9, Am11)
        this.chords = [
          { root: 87.31, notes: [174.61, 261.63, 329.63, 392.00, 523.25, 659.25] },
          { root: 130.81, notes: [261.63, 329.63, 392.00, 493.88, 587.33, 783.99] },
