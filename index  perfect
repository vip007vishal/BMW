        this.mainGain.gain.setValueAtTime(this.mainGain.gain.value, now);
        this.mainGain.gain.linearRampToValueAtTime(0.0, now + 1.2);

        setTimeout(() => {
          if (!this.isPlaying && this.audioCtx) {
            this.audioCtx.close();
            this.audioCtx = null;
          }
