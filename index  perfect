    function applyLightScheme(schemeName) {
      const scheme = lightSchemes[schemeName];
      if (!scheme) return;

      activeSchemes[activeLightTarget] = schemeName;

      if (activeLightTarget === 'all') {
        // Set all specific target schemes to match the global one
        activeSchemes.key = schemeName;
        activeSchemes.rim = schemeName;
        activeSchemes.under = schemeName;
        activeSchemes.ceiling = schemeName;

        tealLights.forEach(light => {
          if (light) light.color.setHex(scheme.teal);
        });
        orangeLights.forEach(light => {
          if (light) light.color.setHex(scheme.orange);
        });
      } else {
        // Apply colors only to the selected group
        const targetLights = lightGroups[activeLightTarget] || [];
        targetLights.forEach(light => {
          if (!light) return;
          if (tealLights.includes(light)) {
            light.color.setHex(scheme.teal);
          } else if (orangeLights.includes(light)) {
            light.color.setHex(scheme.orange);
          }
