      allLights.forEach(light => {
        if (!light) return;
        const base = baseIntensities.get(light) || 0;

        let groupScale = 1.0;
        if (lightGroups.key.includes(light)) {
          groupScale = lightScales.key;
        } else if (lightGroups.rim.includes(light)) {
          groupScale = lightScales.rim;
        } else if (lightGroups.under.includes(light)) {
          groupScale = lightScales.under;
        } else if (lightGroups.ceiling.includes(light)) {
          groupScale = lightScales.ceiling;
        }

        // Proportional mix: base value * target scale * global scale
        light.intensity = base * groupScale * lightScales.all;
      });
    }

