        leftOsc1.frequency.setValueAtTime(bassFreq, now);
        leftOsc2.frequency.setValueAtTime(bassFreq * 2, now);
        leftOsc1.detune.setValueAtTime(-8, now);
        leftOsc2.detune.setValueAtTime(-8, now);

