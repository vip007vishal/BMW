        this.isPlaying = false;

        if (this.chordTimeout) clearTimeout(this.chordTimeout);

        const now = this.audioCtx.currentTime;
        this.mainGain.gain.cancelScheduledValues(now);
        this.mainGain.gain.setValueAtTime(this.mainGain.gain.value, now);
        this.mainGain.gain.linearRampToValueAtTime(0.0, now + 1.5);

        setTimeout(() => {
          if (!this.isPlaying && this.audioCtx) {
            this.audioCtx.close();
            this.audioCtx = null;
          }
        }, 1600);
      }
    }

    class PartyMusicGenerator {
      constructor() {
        this.audioCtx = null;
        this.isPlaying = false;
        this.analyser = null;
        this.mainGain = null;
        this.timerId = null;
        this.nextStepTime = 0.0;
        this.currentStep = 0;
        this.bpm = 124;
        this.stepDuration = 60 / this.bpm / 4;
        this.lookAhead = 0.12;
        this.scheduleInterval = 30;

        this.progression = [
          {
            piano: [220.00, 261.63, 329.63, 440.00],
            strings: [220.00, 329.63],
            bass: 55.00,
            guitar: [261.63, 329.63, 440.00, 392.00]
          },
          {
            piano: [174.61, 261.63, 349.23, 440.00],
            strings: [174.61, 220.00],
            bass: 43.65,
            guitar: [261.63, 349.23, 440.00, 392.00]
          }
        ];
      }

      init() {
        this.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        this.analyser = this.audioCtx.createAnalyser();
        this.analyser.fftSize = 64;

        this.mainGain = this.audioCtx.createGain();
        this.mainGain.gain.setValueAtTime(0.0, this.audioCtx.currentTime);

        this.filterNode = this.audioCtx.createBiquadFilter();
        this.filterNode.type = 'lowpass';
        this.filterNode.frequency.setValueAtTime(2200, this.audioCtx.currentTime);

        this.bassFilterNode = this.audioCtx.createBiquadFilter();
        this.bassFilterNode.type = 'lowpass';
        this.bassFilterNode.frequency.setValueAtTime(140, this.audioCtx.currentTime);

        this.bassDelayNode = this.audioCtx.createDelay(0.1);
        this.bassDelayNode.delayTime.setValueAtTime(0.022, this.audioCtx.currentTime);

        this.bassPanL = this.audioCtx.createStereoPanner ? this.audioCtx.createStereoPanner() : null;
        this.bassPanR = this.audioCtx.createStereoPanner ? this.audioCtx.createStereoPanner() : null;
        if (this.bassPanL) this.bassPanL.pan.setValueAtTime(-0.85, this.audioCtx.currentTime);
        if (this.bassPanR) this.bassPanR.pan.setValueAtTime(0.85, this.audioCtx.currentTime);

        this.filterNode.connect(this.mainGain);

        this.mainGain.connect(this.analyser);
        this.analyser.connect(this.audioCtx.destination);
