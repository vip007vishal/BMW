      start() {
        if (this.isPlaying) return;
        if (!this.audioCtx) this.init();
        if (this.audioCtx.state === 'suspended') this.audioCtx.resume();

        this.isPlaying = true;
        this.mainGain.gain.cancelScheduledValues(this.audioCtx.currentTime);
        this.mainGain.gain.setValueAtTime(0.0, this.audioCtx.currentTime);

        const targetGain = (engineSound.isPlaying || exhaustSound.isPlaying) ? 0.05 : 0.42;
        this.mainGain.gain.linearRampToValueAtTime(targetGain, this.audioCtx.currentTime + 1.5);

        this.currentStep = 0;
        this.nextStepTime = this.audioCtx.currentTime + 0.05;
        this.timerId = setInterval(() => this.scheduler(), this.scheduleInterval);
      }

      fadeTo(targetGain, duration = 1.0) {
