      const min = parseFloat(slider.min) || 0;
      const max = parseFloat(slider.max) || 1;
      const val = parseFloat(slider.value) || 0;
      const pct = ((val - min) / (max - min) * 100).toFixed(1) + '%';
      slider.style.setProperty('--pct', pct);
