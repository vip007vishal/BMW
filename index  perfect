<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description"
    content="Experience the high-performance BMW M4 CS in an interactive 3D studio, exploring its engineering, laser headlights, OLED signatures, and track-focused dynamics.">
  <title>BMW M4 CS</title>
  <style>
    /* --- DESIGN TOKENS & SYSTEM CORE --- */
    :root {
      --color-bg: #040406;
      --color-text: #ffffff;
      --color-accent: #249EA0;
      /* Unified Studio Teal */
      --color-accent-orange: #6b0c0c;
      /* High-Octane Deep Orange */
      --color-muted: #8e8e93;
      --font-display: 'Arial Black', Impact, sans-serif;
      --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body,
    html {
      background-color: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    /* --- BACKGROUND FIXED 3D CANVAS --- */
    #webgl-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 1;
      pointer-events: none;
    }

    /* --- HEADER INTERFACE LAYER --- */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 80px;
      padding: 25px 8%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 10;
      background: rgba(0, 0, 0, 0.195);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .nav-logo {
      width: 40px;
      height: 40px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-logo img {
      width: 100%;
      height: 100%;
      opacity: 0.95;
      object-fit: contain;
      display: block;
    }

    .nav-logo:hover img {
      opacity: 1;
      cursor: pointer;
    }

    nav .brand {
      flex: 1;
      font-family: var(--font-display);
      font-size: 1.4rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: linear-gradient(45deg, #fff, var(--color-accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    nav .nav-links {
      flex: 4;
      text-align: center;
    }

    nav .nav-links a {
      color: var(--color-text);
      text-decoration: none;
      margin: 0 20px;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      transition: 0.3s ease;
    }

    nav .nav-links a:hover {
      background: linear-gradient(to right, #b72211 0%, #18b6b9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    nav .nav-actions {
      flex: 1;
      text-align: right;
    }

    nav .nav-btn {
      color: #fff;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 8px 20px;
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 30px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.15);
      transition: all 0.3s ease-in-out;
    }

    nav .nav-btn:hover {
      background: rgba(242, 242, 242, 0.395);
      border-color: rgba(215, 215, 215, 0.329);
      box-shadow: 0 0 25px rgba(160, 160, 160, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.25);
      transform: translateY(-2px);
    }

    /* --- GRAPHIC CONTENT SECTIONS --- */
    main {
      position: relative;
      z-index: 2;
      width: 100%;
    }

    section {
      position: relative;
      height: 100vh;
      width: 100%;
      display: flex;
      align-items: center;
      padding: 0 8%;
    }

    /* Section 1: Hero Overview */
    #hero {
      justify-content: center;
      align-items: flex-start;
      padding-top: 13vh;
    }

    .hero-image-bottom {
      position: absolute;
      bottom: 3vh;
      left: 50%;
      transform: translateX(-50%);
      height: 100px;
      width: auto;
      z-index: 5;
      display: flex;
      justify-content: center;
      opacity: calc(0.2 * var(--scroll-opacity, 1));
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .hero-image-bottom img {
      height: 100%;
      width: auto;
      object-fit: contain;
    }

    .hero-image-bottom:hover {
      opacity: var(--scroll-opacity, 1);
      transform: translateX(-50%) translateY(-2px);
    }

    .hero-panel {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-panel h1 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 6vw, 6.5rem);
      line-height: 0.95;
      text-transform: uppercase;
      letter-spacing: -3px;
      margin-bottom: 25px;
      background: linear-gradient(to right, #b72211 0%, #18b6b9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1.0) 0%, rgba(0, 0, 0, 0.0) 100%);
      mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1.0) 0%, rgba(0, 0, 0, 0.0) 100%);
    }

    .hero-panel p {
      font-size: 1.1rem;
      color: var(--color-muted);
      max-width: 500px;
      line-height: 1.7;
    }

    .badge {
      position: relative;
      display: inline-block;
      padding: 6px 12px;
      background: rgba(36, 158, 160, 0.15);
      border: 1px solid var(--color-accent);
      color: var(--color-accent);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 10px;
      border-radius: 4px;
    }

    /* Section 2: Under Hood Mechanics */
    #engineering {
      position: relative;
    }

    .hud-callout {
      position: absolute;
      bottom: 50%;
      left: 50%;
      z-index: 10;
    }

    .hud-svg {
      position: absolute;
      bottom: 0;
      left: 0;
      display: block;
      overflow: visible;
    }

    .hud-content {
      position: absolute;
      bottom: 110px;
      left: 250px;
      display: flex;
      gap: 15px;
      align-items: center;
      white-space: nowrap;
      font-family: var(--font-display);
      text-transform: uppercase;
      letter-spacing: 2px;
      background: rgba(0, 0, 0, 0.4);
      padding: 8px 16px;
      border-radius: 4px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .hud-title {
      color: rgba(255, 51, 51, 0.08);
      -webkit-text-stroke: 0.8px rgba(255, 51, 51, 0.45);
      text-shadow:
        0 2px 6px rgba(0, 0, 0, 0.5),
        0 0 1px rgba(255, 51, 51, 0.25);
      font-weight: 700;
      font-size: 0.95rem;
    }

    .hud-sep {
      color: rgba(36, 158, 160, 0.08);
      -webkit-text-stroke: 0.8px rgba(36, 158, 160, 0.45);
      text-shadow:
        0 2px 6px rgba(0, 0, 0, 0.5),
        0 0 1px rgba(36, 158, 160, 0.25);
    }

    .hud-stat {
      color: rgba(228, 228, 231, 0.08);
      -webkit-text-stroke: 0.8px rgba(228, 228, 231, 0.45);
      text-shadow:
        0 2px 6px rgba(0, 0, 0, 0.5),
        0 0 1px rgba(228, 228, 231, 0.25);
      font-size: 0.8rem;
    }

    .glass-card {
      background: rgba(8, 8, 11, 0.4);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid rgba(255, 255, 255, 0.07);
      padding: 45px;
      border-radius: 24px;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
    }

    .glass-card h2 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      text-transform: uppercase;
      margin-bottom: 30px;
      letter-spacing: 1px;
      color: rgba(36, 158, 160, 0.08);
      -webkit-text-stroke: 1px rgba(36, 158, 160, 0.35);
      text-shadow:
        0 4px 12px rgba(0, 0, 0, 0.6),
        0 0 4px rgba(36, 158, 160, 0.3),
        0 0 1px rgba(36, 158, 160, 0.5);
    }

    .glass-card p,
    .cockpit-spec p {
      font-size: 0.95rem;
      color: rgba(228, 228, 231, 0.75);
      line-height: 1.6;
      letter-spacing: 0.5px;
      font-weight: 400;
    }

    .stat-row {
      margin-bottom: 25px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding-bottom: 15px;
    }

    .stat-row:last-child {
      margin-bottom: 0;
      border-bottom: none;
      padding-bottom: 0;
    }

    .stat-row .label {
      font-size: 0.75rem;
      color: var(--color-muted);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 5px;
    }

    .stat-row .value {
      font-family: var(--font-display);
      font-size: 2.2rem;
    }

    .value-teal {
      color: var(--color-accent);
    }

    .value-orange {
      color: var(--color-accent-orange);
    }

    .background-logo-wrapper {
      position: absolute;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 0;
      /* behind canvas */
      pointer-events: none;
      opacity: 0.15;
    }

    .background-logo-wrapper img {
      width: 100vw;
      height: auto;
    }

    /* Section 3: Driver Cockpit (Steering Calibration View) */
    #cockpit {
      justify-content: flex-start;
      align-items: flex-start;
      padding-top: 15vh;
      padding-left: 4%;
    }

    #headlight {
      justify-content: flex-end;
    }

    #tyres {
      justify-content: flex-start;
    }

    #exhaust {
      justify-content: space-between;
    }

    #taillight {
      justify-content: flex-start;
    }

    #brand {
      justify-content: flex-end;
    }

    .cockpit-spec {
      max-width: 460px;
      text-align: left;
    }

    .cockpit-spec h2 {
      font-family: var(--font-display);
      font-size: 2.5rem;
      text-transform: uppercase;
      margin-bottom: 20px;
      color: rgba(255, 51, 51, 0.08);
      -webkit-text-stroke: 1px rgba(255, 51, 51, 0.35);
      text-shadow:
        0 4px 12px rgba(0, 0, 0, 0.6),
        0 0 1px rgba(255, 51, 51, 0.2);
    }

    .cockpit-spec ul {
      list-style: none;
      margin-top: 20px;
    }

    .cockpit-spec ul li {
      position: relative;
      padding-left: 25px;
      margin-bottom: 15px;
      color: rgba(228, 228, 231, 0.75);
      font-size: 0.95rem;
      line-height: 1.6;
      letter-spacing: 0.5px;
    }

    .cockpit-spec ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      background: var(--color-accent);
      border-radius: 50%;
    }

    /* Section 4: Exit & Outro Stance */
    #cta {
      justify-content: center;
      text-align: center;
    }

    .cta-panel {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .cta-panel h2 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      text-transform: uppercase;
      letter-spacing: -2px;
      margin-bottom: 20px;
      color: rgba(255, 255, 255, 0.08);
      -webkit-text-stroke: 1px rgba(255, 255, 255, 0.25);
      text-shadow:
        0 4px 12px rgba(0, 0, 0, 0.6),
        0 0 1px rgba(255, 255, 255, 0.05);
      white-space: nowrap;
    }

    .action-btn {
      display: inline-block;
      padding: 12px 32px;
      background: rgba(255, 255, 255, 0.08);
      color: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      text-decoration: none;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 2px;
      border-radius: 50px;
      font-size: 0.85rem;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .action-btn:hover {
      background: var(--color-accent);
      color: #ffffff;
      border-color: var(--color-accent);
      box-shadow: 0 0 30px rgba(36, 158, 160, 0.5);
      transform: translateY(-4px);
    }

    /* Glass Audio Player components */
    .glass-audio-player {
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.01) 80%), rgba(8, 8, 12, 0.35);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-top: 1.5px solid rgba(255, 255, 255, 0.2);
      border-left: 1.5px solid rgba(255, 255, 255, 0.2);
      padding: 10px 20px;
      border-radius: 50px;
      display: inline-flex;
      align-items: center;
      gap: 15px;
      box-shadow:
        0 15px 35px rgba(0, 0, 0, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      z-index: 10;
      pointer-events: auto;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .glass-audio-player:hover {
      transform: translateY(-2px) scale(1.02);
      border-color: rgba(255, 255, 255, 0.15);
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.02) 80%), rgba(12, 12, 18, 0.45);
    }

    @keyframes enginePulse {
      0% {
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.15), 0 0 15px rgba(36, 158, 160, 0.1);
      }

      50% {
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.25), 0 0 25px rgba(36, 158, 160, 0.3);
      }

      100% {
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.15), 0 0 15px rgba(36, 158, 160, 0.1);
      }
    }

    @keyframes exhaustPulse {
      0% {
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.15), 0 0 15px rgba(196, 69, 54, 0.1);
      }

      50% {
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.25), 0 0 25px rgba(196, 69, 54, 0.3);
      }

      100% {
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.15), 0 0 15px rgba(196, 69, 54, 0.1);
      }
    }

    .glass-audio-player.playing#engine-player {
      animation: enginePulse 3s infinite ease-in-out;
      border-color: rgba(36, 158, 160, 0.35);
    }

    .glass-audio-player.playing#exhaust-player {
      animation: exhaustPulse 3s infinite ease-in-out;
      border-color: rgba(196, 69, 54, 0.35);
    }

    .glass-audio-player .play-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #fff;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      outline: none;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
      padding: 0;
      flex-shrink: 0;
    }

    .glass-audio-player .play-btn:hover {
      background: var(--color-accent);
      border-color: var(--color-accent);
      box-shadow: 0 0 15px rgba(36, 158, 160, 0.6);
      transform: scale(1.08);
    }

    #exhaust-player .play-btn:hover {
      background: #c44536;
      border-color: #c44536;
      box-shadow: 0 0 15px rgba(196, 69, 54, 0.6);
    }

    .glass-audio-player .play-btn svg {
      width: 14px;
      height: 14px;
      fill: currentColor;
    }

    .glass-audio-player .player-info {
      display: flex;
      flex-direction: column;
      text-transform: uppercase;
      font-family: var(--font-body);
      letter-spacing: 1.5px;
      min-width: 110px;
    }

    .glass-audio-player .player-title {
      font-size: 0.68rem;
      font-weight: 800;
      color: #fff;
      line-height: 1.2;
    }

    .glass-audio-player .player-subtitle {
      font-size: 0.48rem;
      color: var(--color-muted);
      margin-top: 2px;
      line-height: 1.2;
    }

    .glass-audio-player .wave-visualizer {
      display: block;
      width: 160px;
      height: 40px;
      background: transparent;
      border-radius: 4px;
    }

    /* Section placement: placed exactly opposite (horizontally aligned) to the power assembly callout card */
    #engineering .audio-player-wrapper {
      position: absolute;
      right: calc(50% + 250px);
      bottom: calc(50% + 110px);
    }

    /* Showroom Background Music Toggle */
    .bg-music-toggle {
      position: fixed;
      top: 110px;
      right: 30px;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.01) 80%), rgba(8, 8, 12, 0.35);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-top: 1.5px solid rgba(255, 255, 255, 0.18);
      border-left: 1.5px solid rgba(255, 255, 255, 0.18);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: rgba(255, 255, 255, 0.7);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      z-index: 15;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      outline: none;
      padding: 0;
    }

    .bg-music-toggle:hover {
      color: #fff;
      border-color: rgba(255, 255, 255, 0.18);
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.02) 80%), rgba(12, 12, 18, 0.45);
      transform: translateY(-2px) scale(1.05);
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    .bg-music-toggle:active {
      transform: translateY(0px) scale(0.98);
    }

    .bg-music-toggle.left-btn {
      right: auto;
      left: 30px;
    }

    .bg-music-toggle svg {
      width: 24px;
      height: 24px;
      display: block;
    }

    @keyframes spinTyre {
      from {
        transform: rotate(0deg);
      }

      to {
        transform: rotate(360deg);
      }
    }

    .bg-music-toggle svg.tyre-icon {
      animation: spinTyre 6s infinite linear;
      animation-play-state: paused;
      transition: color 0.4s ease;
    }

    .bg-music-toggle.playing svg.tyre-icon {
      animation-play-state: running;
      color: var(--color-accent);
    }

    /* Mobile Toggle Button */
    .mobile-nav-toggle {
      display: none;
      background: transparent;
      border: none;
      color: #fff;
      cursor: pointer;
      width: 44px;
      height: 44px;
      padding: 2px;
      align-items: center;
      justify-content: center;
      z-index: 11;
      transition: all 0.3s ease;
      outline: none;
    }

    .mobile-nav-toggle svg {
      width: 100%;
      height: 100%;
      display: block;
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .mobile-nav-toggle:hover {
      color: var(--color-accent);
      transform: scale(1.05);
    }

    .mobile-nav-toggle:active {
      transform: scale(0.95);
    }

    /* Mobile Overlay Menu Drawer */
    .mobile-menu-overlay {
      position: fixed;
      top: 80px;
      /* Directly below fixed navbar */
      left: 0;
      width: 100%;
      height: 0;
      background: radial-gradient(circle at 50% 50%, rgba(8, 8, 12, 0.98) 0%, rgba(4, 4, 6, 0.99) 100%);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      overflow: hidden;
      z-index: 9;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      border-bottom: 0px solid rgba(255, 255, 255, 0.0);
    }

    .mobile-menu-overlay.active {
      height: calc(100vh - 80px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .mobile-menu-links {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 30px;
      opacity: 0;
      transform: translateY(-20px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.1s;
    }

    .mobile-menu-overlay.active .mobile-menu-links {
      opacity: 1;
      transform: translateY(0);
    }

    .mobile-menu-links a {
      color: #fff;
      text-decoration: none;
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: 4px;
      text-transform: uppercase;
      transition: all 0.3s ease;
    }

    .mobile-menu-links a:hover {
      color: var(--color-accent);
      text-shadow: 0 0 10px rgba(36, 158, 160, 0.4);
    }

    .mobile-menu-actions {
      margin-top: 50px;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
    }

    .mobile-menu-overlay.active .mobile-menu-actions {
      opacity: 1;
      transform: translateY(0);
    }

    /* --- RESPONSIVE ADAPTATION --- */
    @media (max-width: 968px) {
      section {
        justify-content: center !important;
        text-align: center;
      }

      .hero-panel p,
      .cockpit-spec p {
        margin: 0 auto;
      }

      .cockpit-spec ul li {
        text-align: left;
      }

      #engineering .audio-player-wrapper {
        position: relative;
        left: auto;
        right: auto;
        bottom: auto;
        margin: 20px auto;
        display: flex;
        justify-content: center;
      }

      nav {
        padding: 20px 6%;
      }

      nav .brand {
        flex: 1;
        font-size: 1.2rem;
        text-align: left;
        margin-left: 15px;
      }

      nav .nav-links,
      nav .nav-actions,
      nav .nav-logo:last-of-type {
        display: none !important;
      }

      .mobile-nav-toggle {
        display: flex !important;
      }
    }

    /* Loading Infrastructure overlay */
    #loader {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: var(--color-bg);
      z-index: 100;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      transition: opacity 0.6s ease;
    }

    .spinner {
      width: 50px;
      height: 50px;
      border: 3px solid rgba(255, 255, 255, 0.05);
      border-top-color: var(--color-accent);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-bottom: 20px;
      color: #000038;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    /* Scene mode transition overlay */
    #scene-loading-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(4, 4, 6, 0.82);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 200;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 18px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    #scene-loading-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }

    .scene-spinner {
      width: 36px;
      height: 36px;
      border: 2.5px solid rgba(255, 255, 255, 0.08);
      border-top-color: var(--color-accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    .scene-loading-label {
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: rgba(255, 255, 255, 0.55);
    }

    /* --- INTERACTIVE CONTROLS HUD (Doors & Hood) --- */
    .car-controls-hud {
      position: fixed;
      top: 30px;
      left: 30px;
      z-index: 120;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 8px;
      opacity: 0;
      pointer-events: none;
      transform: translateX(-80px);
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    body.free-roam-active .car-controls-hud {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
    }

    .car-ctrl-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 9px 16px;
      border-radius: 22px;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.07) 0%, rgba(255, 255, 255, 0.01) 80%), rgba(8, 8, 12, 0.65);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-top: 1.5px solid rgba(255, 255, 255, 0.18);
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.68rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      cursor: pointer;
      outline: none;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      white-space: nowrap;
    }

    .car-ctrl-btn:hover {
      color: #fff;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0.03) 80%), rgba(12, 12, 18, 0.75);
      border-color: rgba(255, 255, 255, 0.22);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5), 0 0 12px rgba(36, 158, 160, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.15);
      transform: translateY(-2px);
    }

    .car-ctrl-btn.active-open {
      border-color: var(--color-accent);
      color: var(--color-accent);
      box-shadow: 0 0 14px rgba(36, 158, 160, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }

    .car-ctrl-btn svg {
      width: 14px;
      height: 14px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex-shrink: 0;
    }

    .ctrl-divider {
      width: 1px;
      height: 22px;
      background: rgba(255, 255, 255, 0.08);
      margin: 0 4px;
      align-self: center;
    }

    /* --- FREE ROAM CAM VIEW & BLENDER CONTROLS --- */
    body.free-roam-active {
      overflow: hidden !important;
      height: 100vh;
    }

    body.free-roam-active #webgl-canvas {
      pointer-events: auto;
      cursor: grab;
    }

    body.free-roam-active #webgl-canvas:active {
      cursor: grabbing;
    }

    main,
    nav,
    .bg-music-toggle {
      transition: opacity 0.5s ease, visibility 0.5s ease;
    }

    body.free-roam-active main,
    body.free-roam-active nav,
    body.free-roam-active .bg-music-toggle {
      opacity: 0 !important;
      pointer-events: none !important;
      visibility: hidden;
    }

    .free-roam-btn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 99;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 80%), rgba(8, 8, 12, 0.45);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-top: 1.5px solid rgba(255, 255, 255, 0.2);
      border-left: 1.5px solid rgba(255, 255, 255, 0.2);
      padding: 12px 24px;
      border-radius: 30px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: #fff;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.8rem;
      cursor: pointer;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .free-roam-btn:hover {
      background: var(--color-accent);
      border-color: var(--color-accent);
      box-shadow: 0 0 30px rgba(36, 158, 160, 0.6);
      transform: translateY(-4px);
    }

    .free-roam-btn:active {
      transform: translateY(-1px);
    }

    .free-roam-btn svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    body.free-roam-active .free-roam-btn {
      opacity: 0;
      pointer-events: none;
      transform: translateY(20px);
    }

    /* --- SCENE MODE TOGGLE (Cinematic / Studio) --- */
    .scene-mode-toggle {
      position: fixed;
      top: 96px;
      left: 50%;
      transform: translateX(-50%) translateY(-80px);
      z-index: 120;
      opacity: 0;
      pointer-events: none;
      transition: all 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    }

    body.free-roam-active .scene-mode-toggle {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .scene-mode-inner {
      position: relative;
      display: flex;
      align-items: center;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.07) 0%, rgba(255, 255, 255, 0.01) 80%), rgba(8, 8, 12, 0.65);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-top: 1.5px solid rgba(255, 255, 255, 0.18);
      border-radius: 40px;
      padding: 5px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      gap: 2px;
    }

    /* Sliding active indicator */
    .scene-mode-inner::before {
      content: '';
      position: absolute;
      left: 5px;
      top: 5px;
      width: calc(50% - 5px);
      height: calc(100% - 10px);
      border-radius: 35px;
      background: linear-gradient(135deg, var(--color-accent) 0%, rgba(36, 158, 160, 0.75) 100%);
      box-shadow: 0 0 18px rgba(36, 158, 160, 0.55), inset 0 1px 0 rgba(255, 255, 255, 0.2);
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      z-index: 0;
    }

    .scene-mode-inner.studio-active::before {
      left: calc(50% + 0px);
    }

    .scene-mode-btn {
      position: relative;
      z-index: 1;
      padding: 8px 22px;
      border: none;
      background: transparent;
      cursor: pointer;
      outline: none;
      border-radius: 35px;
      display: flex;
      align-items: center;
      gap: 7px;
      transition: color 0.3s ease;
      font-size: 0.7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.8px;
      color: rgba(255, 255, 255, 0.45);
      white-space: nowrap;
    }

    .scene-mode-btn.active {
      color: #fff;
    }

    .scene-mode-btn svg {
      width: 13px;
      height: 13px;
      flex-shrink: 0;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: filter 0.3s ease;
    }

    .scene-mode-btn.active svg {
      filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.6));
    }


    .free-roam-hud {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%) translateY(120px);
      z-index: 110;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 80%), rgba(8, 8, 12, 0.6);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 10px 24px;
      border-radius: 30px;
      display: flex;
      align-items: center;
      gap: 18px;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      opacity: 0;
      pointer-events: none;
      white-space: nowrap;
    }

    body.free-roam-active .free-roam-hud {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .free-roam-hud h3 {
      display: none;
    }

    .free-roam-hud-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.78rem;
    }

    .free-roam-hud-label {
      color: var(--color-muted);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .free-roam-hud-key {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      padding: 3px 6px;
      border-radius: 5px;
      font-size: 0.7rem;
      font-weight: bold;
      color: #fff;
      font-family: monospace;
    }

    @media (max-width: 1200px) {
      .free-roam-hud {
        gap: 12px;
        padding: 8px 18px;
      }

      .free-roam-hud-item {
        font-size: 0.7rem;
        gap: 6px;
      }

      .free-roam-exit-btn {
        padding: 6px 12px;
        font-size: 0.65rem;
      }
    }

    .free-roam-exit-btn {
      padding: 8px 16px;
      border-radius: 20px;
      background: rgba(196, 69, 54, 0.15);
      border: 1px solid #c44536;
      color: #fff;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-size: 0.7rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.3s ease;
      margin-left: 10px;
      outline: none;
    }

    .free-roam-exit-btn:hover {
      background: #c44536;
      box-shadow: 0 0 20px rgba(196, 69, 54, 0.6);
      transform: translateY(-2px);
    }

    .free-roam-exit-btn svg {
      width: 12px;
      height: 12px;
      fill: currentColor;
    }

    /* Light target switcher */
    .light-target-selector {
      display: flex;
      gap: 6px;
      width: 100%;
    }

    .light-target-btn {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.55rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 5px 1px;
      border-radius: 12px;
      cursor: pointer;
      flex: 1;
      text-align: center;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      outline: none;
    }

    .light-target-btn:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.1);
    }

    .light-target-btn.active {
      background: var(--color-accent);
      border-color: var(--color-accent);
      color: #fff;
      box-shadow: 0 0 10px rgba(36, 158, 160, 0.4);
    }

    /* --- COLOR CUSTOMIZATION SELECTION PILL --- */
    .color-pill-container {
      position: fixed;
      right: 30px;
      top: 50%;
      transform: translateY(-50%) translateX(120px);
      z-index: 100;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.01) 80%), rgba(8, 8, 12, 0.55);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-top: 1.5px solid rgba(255, 255, 255, 0.18);
      border-left: 1.5px solid rgba(255, 255, 255, 0.18);
      border-radius: 15px;
      padding: 24px 14px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 18px;
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      opacity: 0;
      pointer-events: none;
    }

    body.free-roam-active .color-pill-container {
      transform: translateY(-50%) translateX(0);
      opacity: 1;
      pointer-events: auto;
    }

    .color-target-selector {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: center;
    }

    .target-btn {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.62rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      padding: 6px 12px;
      border-radius: 20px;
      cursor: pointer;
      width: 72px;
      text-align: center;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      outline: none;
    }

    .target-btn:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.2);
    }

    .target-btn.active {
      background: var(--color-accent);
      border-color: var(--color-accent);
      color: #fff;
      box-shadow: 0 0 12px rgba(36, 158, 160, 0.4);
    }

    .color-divider {
      width: 100%;
      height: 1px;
      background: rgba(255, 255, 255, 0.08);
    }

    .color-options-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      justify-items: center;
    }

    .color-opt-btn {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      padding: 0;
      outline: none;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
    }

    .color-opt-btn:hover {
      transform: scale(1.2);
    }

    .color-opt-btn.active {
      border-color: #fff;
      box-shadow: 0 0 15px rgba(255, 255, 255, 0.6);
      transform: scale(1.1);
    }

    .color-opt-btn.default-opt {
      grid-column: span 2;
      width: 100%;
      height: 28px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px dashed rgba(255, 255, 255, 0.5);
      color: rgba(255, 255, 255, 0.7);
      box-shadow: none;
    }

    .color-opt-btn.default-opt:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.12);
      border-color: #fff;
    }

    .color-opt-btn.default-opt.active {
      border: 2px solid #fff;
      color: #fff;
      background: rgba(255, 255, 255, 0.15);
    }

    .color-opt-btn.default-opt svg {
      width: 14px;
      height: 14px;
      fill: none;
    }

    /* --- CUSTOM PANEL COLLAPSIBLE TOGGLES --- */
    .pill-toggle-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 20px;
      height: 52px;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 80%), rgba(8, 8, 12, 0.75);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      outline: none;
      z-index: 10;
    }

    #color-pill-toggle {
      left: -20px;
      border-radius: 10px 0 0 10px;
      border-right: none;
    }

    #color-pill-toggle:hover {
      color: #fff;
      background: rgba(8, 8, 12, 0.9);
      box-shadow: -5px 0 15px rgba(0, 0, 0, 0.4);
    }

    #light-pill-toggle {
      right: -20px;
      border-radius: 0 10px 10px 0;
      border-left: none;
    }

    #light-pill-toggle:hover {
      color: #fff;
      background: rgba(8, 8, 12, 0.9);
      box-shadow: 5px 0 15px rgba(0, 0, 0, 0.4);
    }

    .toggle-icon {
      width: 12px;
      height: 12px;
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Collapse animation modifiers */
    .color-pill-container.collapsed {
      transform: translateY(-50%) translateX(calc(100% + 40px)) !important;
      opacity: 0;
      pointer-events: none;
    }

    .light-pill-container.collapsed {
      transform: translateY(-50%) translateX(calc(-100% - 40px)) !important;
      opacity: 0;
      pointer-events: none;
    }

    /* --- SLEEK COLLAPSED FLOATING CIRCLE TRIGGERS --- */
    .collapsed-pill-trigger {
      position: fixed;
      top: 50%;
      transform: translateY(-50%) scale(0);
      opacity: 0;
      pointer-events: none;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 80%), rgba(8, 8, 12, 0.55);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-top: 1.5px solid rgba(255, 255, 255, 0.22);
      border-left: 1.5px solid rgba(255, 255, 255, 0.22);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-accent);
      cursor: pointer;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.15);
      z-index: 100;
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      padding: 0;
      outline: none;
    }

    #light-pill-collapsed-trigger {
      left: 30px;
    }

    #color-pill-collapsed-trigger {
      right: 30px;
    }

    .collapsed-pill-trigger:hover {
      color: #fff;
      background: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0.04) 80%), rgba(8, 8, 12, 0.7);
      border-color: rgba(255, 255, 255, 0.25);
      box-shadow: 0 0 15px rgba(36, 158, 160, 0.5);
      transform: translateY(-50%) scale(1.08);
    }

    .collapsed-pill-trigger:active {
      transform: translateY(-50%) scale(0.98);
    }

    .collapsed-pill-trigger svg {
      width: 22px;
      height: 22px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    body.free-roam-active #light-pill-collapsed-trigger.visible,
    body.free-roam-active #color-pill-collapsed-trigger.visible {
      transform: translateY(-50%) scale(1);
      opacity: 1;
      pointer-events: auto;
    }

    /* --- LIGHT CONTROL PANEL (LEFT SIDE) --- */
    .light-pill-container {
      position: fixed;
      left: 30px;
      top: 50%;
      transform: translateY(-50%) translateX(-380px);
      z-index: 100;
