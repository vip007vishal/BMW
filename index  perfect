          if (sideIcon) sideIcon.style.display = 'block';
        } else {
          if (frontIcon) frontIcon.style.display = 'block';
          if (sideIcon) sideIcon.style.display = 'none';
        }
      });

      mobileOverlayLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileOverlay.classList.remove('active');
          if (frontIcon) frontIcon.style.display = 'block';
          if (sideIcon) sideIcon.style.display = 'none';
        });
      });
    }

    setupAudioPlayer('engine-player', engineSound);
    setupAudioPlayer('exhaust-player', exhaustSound);

    // Start engine loops
    cycleRenderFrame();
  </script>
</body>

</html>