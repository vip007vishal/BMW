        const now = this.audioCtx.currentTime;
        this.mainGain.gain.cancelScheduledValues(now);
        this.mainGain.gain.setValueAtTime(this.mainGain.gain.value, now);
        this.mainGain.gain.linearRampToValueAtTime(targetGain, now + duration);
      }

      scheduler() {
        if (!this.isPlaying) return;
        while (this.nextStepTime < this.audioCtx.currentTime + this.lookAhead) {
          this.scheduleStep(this.currentStep, this.nextStepTime);
          this.nextStepTime += this.stepDuration;
          this.currentStep = (this.currentStep + 1) % 32;
        }
      }

      scheduleStep(step, time) {
        const measureIdx = Math.floor(step / 16);
        const localStep = step % 16;
        const section = this.progression[measureIdx];

        if (localStep === 0 || localStep === 4 || localStep === 8 || localStep === 12) {
          this.playKick(time);
        }

        if (localStep === 8) {
          this.playSnare(time);
        } else if (localStep === 14 && step === 30) {
          this.playSnare(time, 0.4);
        }

        if (localStep === 2 || localStep === 6 || localStep === 10 || localStep === 14) {
          this.playHat(time, false);
        }
        if (localStep === 4 || localStep === 12) {
          this.playHat(time, true);
        }

        const bassPattern = [0, 2, 3, 5, 8, 10, 11, 13];
        if (bassPattern.includes(localStep)) {
          const dur = this.stepDuration * (localStep === 3 || localStep === 11 ? 1.8 : 0.95);
          this.playBass(time, section.bass, dur);
        }

        if (localStep === 0) {
          this.playPiano(time, section.piano, this.stepDuration * 3.5);
        } else if (localStep === 6) {
          this.playPiano(time, section.piano, this.stepDuration * 1.8);
        } else if (localStep === 10) {
          this.playPiano(time, section.piano, this.stepDuration * 3.5);
        }

        if (localStep === 0) {
          this.playStrings(time, section.strings, this.stepDuration * 16);
        }

        if (localStep === 2) {
          this.playGuitar(time, section.guitar[0], this.stepDuration * 2);
        } else if (localStep === 5) {
          this.playGuitar(time, section.guitar[1], this.stepDuration * 1.5);
        } else if (localStep === 7) {
          this.playGuitar(time, section.guitar[2], this.stepDuration * 2);
        } else if (localStep === 13) {
          this.playGuitar(time, section.guitar[3], this.stepDuration * 2);
        }

        if (localStep === 0) {
          this.playViolin(time, measureIdx === 0 ? 440.00 : 587.33, this.stepDuration * 3.8);
        } else if (localStep === 4) {
          this.playViolin(time, measureIdx === 0 ? 493.88 : 523.25, this.stepDuration * 3.8);
        } else if (localStep === 8) {
          this.playViolin(time, measureIdx === 0 ? 523.25 : 440.00, this.stepDuration * 7.5);
        }
      }

      playKick(time) {
        const osc = this.audioCtx.createOscillator();
        const gain = this.audioCtx.createGain();
        osc.connect(gain);
        gain.connect(this.mainGain);
        osc.frequency.setValueAtTime(140, time);
        osc.frequency.exponentialRampToValueAtTime(38, time + 0.22);
        gain.gain.setValueAtTime(1.1, time);
        gain.gain.exponentialRampToValueAtTime(0.001, time + 0.22);
        osc.start(time);
        osc.stop(time + 0.24);
