        const rightOsc2 = this.audioCtx.createOscillator();
        rightOsc1.type = 'sine';
        rightOsc2.type = 'triangle';
        rightOsc1.frequency.setValueAtTime(bassFreq, now);
        rightOsc2.frequency.setValueAtTime(bassFreq * 2, now);
        rightOsc1.detune.setValueAtTime(8, now);
        rightOsc2.detune.setValueAtTime(8, now);

        const bassGainL = this.audioCtx.createGain();
        const bassGainR = this.audioCtx.createGain();
        bassGainL.gain.setValueAtTime(0.0, now);
        bassGainR.gain.setValueAtTime(0.0, now);

        bassGainL.gain.linearRampToValueAtTime(0.24, now + 0.40);
        bassGainL.gain.setValueAtTime(0.24, now + 2.4);
        bassGainL.gain.exponentialRampToValueAtTime(0.001, now + duration - 0.5);

        bassGainR.gain.linearRampToValueAtTime(0.24, now + 0.40);
        bassGainR.gain.setValueAtTime(0.24, now + 2.4);
        bassGainR.gain.exponentialRampToValueAtTime(0.001, now + duration - 0.5);

        leftOsc1.connect(this.bassFilterNode);
        leftOsc2.connect(this.bassFilterNode);
        this.bassFilterNode.connect(bassGainL);
        if (this.bassPanL) {
          bassGainL.connect(this.bassPanL);
          this.bassPanL.connect(this.mainGain);
        } else {
          bassGainL.connect(this.mainGain);
        }

        rightOsc1.connect(this.bassFilterNode);
        rightOsc2.connect(this.bassFilterNode);
        this.bassFilterNode.connect(this.bassDelayNode);
        this.bassDelayNode.connect(bassGainR);
        if (this.bassPanR) {
          bassGainR.connect(this.bassPanR);
          this.bassPanR.connect(this.mainGain);
        } else {
          bassGainR.connect(this.mainGain);
        }

        leftOsc1.start(now);
        leftOsc2.start(now);
        rightOsc1.start(now);
        rightOsc2.start(now);

        chordOscillators.push(leftOsc1, leftOsc2, rightOsc1, rightOsc2);
        chordGains.push(bassGainL, bassGainR);

        this.currentChordIdx = (this.currentChordIdx + 1) % this.chords.length;

        setTimeout(() => {
          chordOscillators.forEach(osc => {
            try { osc.stop(); } catch (e) {}
            try { osc.disconnect(); } catch (e) {}
          });
          chordGains.forEach(g => {
            try { g.disconnect(); } catch (e) {}
          });
        }, duration * 1000 + 2000);

        this.chordTimeout = setTimeout(() => this.playNextChord(), (duration - 1.5) * 1000);
      }

      stop() {
