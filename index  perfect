        gain.gain.setValueAtTime(0.0, time);
        gain.gain.linearRampToValueAtTime(0.07, time + 0.16);
        gain.gain.setValueAtTime(0.07, time + duration - 0.16);
        gain.gain.exponentialRampToValueAtTime(0.001, time + duration);

        osc.connect(resonanceFilter);
        resonanceFilter.connect(gain);
        gain.connect(this.mainGain);

        vibratoLfo.start(time);
        osc.start(time);
        vibratoLfo.stop(time + duration);
        osc.stop(time + duration);
      }

