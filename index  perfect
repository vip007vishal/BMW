    function cycleRenderFrame() {
      const currentTime = performance.now();
      const deltaTime = Math.min((currentTime - lastTime) / 1000, 0.1);
      lastTime = currentTime;
      timeElapsed += deltaTime;

      // Frame-rate independent responsive smoothing
      // scrollSpeed = 4.5 gives responsive yet smooth scroll tracking
      const scrollEase = 1 - Math.exp(-4.5 * deltaTime);
      globalScrollProgress += (targetScrollProgress - globalScrollProgress) * scrollEase;

      // Find which segment we are in
      let currentSeg = 0;
      for (let i = 0; i < timeline.length - 1; i++) {
        if (globalScrollProgress >= timeline[i].progress && globalScrollProgress <= timeline[i + 1].progress) {
          currentSeg = i;
          break;
        }
      }
      if (globalScrollProgress >= 1.0) currentSeg = timeline.length - 2;

      const segStart = timeline[currentSeg];
      const segEnd = timeline[currentSeg + 1];

      const stepProgress = (globalScrollProgress - segStart.progress) / (segEnd.progress - segStart.progress);

      const startY = -boxLimits.min.y + (segStart.carYOffset !== undefined ? segStart.carYOffset : -1.3);
      const endY = -boxLimits.min.y + (segEnd.carYOffset !== undefined ? segEnd.carYOffset : -1.3);
      const nextCarY = THREE.MathUtils.lerp(
        startY,
        endY,
        stepProgress
      );

      if (carModel) {
        carModel.position.y = nextCarY;
      }

      nextCamPos.set(
        THREE.MathUtils.lerp(segStart.camPos[0], segEnd.camPos[0], stepProgress),
        THREE.MathUtils.lerp(segStart.camPos[1], segEnd.camPos[1], stepProgress),
        THREE.MathUtils.lerp(segStart.camPos[2], segEnd.camPos[2], stepProgress)
      );

      nextCamTarget.set(
        THREE.MathUtils.lerp(segStart.camTarget[0], segEnd.camTarget[0], stepProgress),
        THREE.MathUtils.lerp(segStart.camTarget[1], segEnd.camTarget[1], stepProgress),
        THREE.MathUtils.lerp(segStart.camTarget[2], segEnd.camTarget[2], stepProgress)
      );

      nextHoodRotation = THREE.MathUtils.lerp(segStart.hood, segEnd.hood, stepProgress);
      nextDriverDoorRotation = THREE.MathUtils.lerp(segStart.doorL, segEnd.doorL, stepProgress);
      nextPassengerDoorRotation = THREE.MathUtils.lerp(segStart.doorR, segEnd.doorR, stepProgress);

      // In free roam mode, use manual button targets instead of scroll timeline
      if (freeRoamActive) {
        nextHoodRotation = manualHoodOpen ? HOOD_OPEN_ROT : 0;
        nextDriverDoorRotation = manualDoorLeftOpen ? DOOR_OPEN_ROT : 0;
        nextPassengerDoorRotation = manualDoorRightOpen ? DOOR_OPEN_ROT : 0;
      }

      // --- UNIFIED SMOOTH LERP RESOLUTIONS MATRIX ---
      // camEase = 6.0 ensures camera and mesh parts follow target positions dynamically with low latency
      const camEase = 1 - Math.exp(-6.0 * deltaTime);
      if (freeRoamActive) {
        const offset = new THREE.Vector3();
        offset.x = freeRoamRadius * Math.sin(freeRoamPhi) * Math.sin(freeRoamTheta);
        offset.y = freeRoamRadius * Math.cos(freeRoamPhi);
        offset.z = freeRoamRadius * Math.sin(freeRoamPhi) * Math.cos(freeRoamTheta);

        const targetCamPos = new THREE.Vector3().addVectors(freeRoamTarget, offset);

        const freeEase = 1 - Math.exp(-12.0 * deltaTime); // Snappy camera following
        liveCamPos.lerp(targetCamPos, freeEase);
        liveCamTarget.lerp(freeRoamTarget, freeEase);
      } else {
        liveCamPos.lerp(nextCamPos, camEase);
        liveCamTarget.lerp(nextCamTarget, camEase);
      }

      camera.position.copy(liveCamPos);
      camera.lookAt(liveCamTarget);

      // Interpolate mesh components if discovered successfully in glTF graph traversal
      if (hoodGroup) {
        hoodGroup.rotation.x = THREE.MathUtils.lerp(hoodGroup.rotation.x, nextHoodRotation, camEase);
      }

      if (driverDoorGroup) {
        driverDoorGroup.rotation.y = THREE.MathUtils.lerp(driverDoorGroup.rotation.y, nextDriverDoorRotation, camEase);
      } else {
        driverDoorMeshNodes.forEach(node => { node.rotation.y = THREE.MathUtils.lerp(node.rotation.y, nextDriverDoorRotation, camEase); });
      }

      if (passengerDoorGroup) {
        passengerDoorGroup.rotation.y = THREE.MathUtils.lerp(passengerDoorGroup.rotation.y, -nextPassengerDoorRotation, camEase);
      } else {
        passengerDoorMeshNodes.forEach(node => { node.rotation.y = THREE.MathUtils.lerp(node.rotation.y, -nextPassengerDoorRotation, camEase); });
      }
      steeringWheelMeshNodes.forEach(node => {
        // Rotate steering wheel subtly with time during cockpit stop phase to emphasize reality accents
        if (globalScrollProgress > 0.66 && globalScrollProgress <= 0.88) {
          node.rotation.z = Math.sin(timeElapsed * 1.5) * 0.25;
        } else {
          node.rotation.z = THREE.MathUtils.lerp(node.rotation.z, 0, camEase);
        }
      });

      // Smoothly hide hero bottom image based on scroll progress (reaches 0 by progress 0.050)
      if (_heroImageElement) {
        const scrollOpacity = Math.max(0, 1 - (globalScrollProgress / 0.050));
        _heroImageElement.style.setProperty('--scroll-opacity', scrollOpacity);
        _heroImageElement.style.pointerEvents = scrollOpacity <= 0 ? 'none' : 'auto';
      }

      renderer.render(scene, camera);
      window.requestAnimationFrame(cycleRenderFrame);
    }

    // 5. VIEWPORT TRANSLATOR ADJUSTMENT LISTENER
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    // --- 6. INTERACTIVE AUDIO SYNTHESIS & WAVE VISUALIZER ---
    class EngineSoundGenerator {
      constructor(type = 'engine') {
        this.type = type;
        this.audioCtx = null;
        this.analyser = null;
        this.isPlaying = false;
        this.oscillators = [];
        this.gainNode = null;
        this.filterNode = null;
        this.noiseNode = null;
        this.noiseFilter = null;
        this.lfo = null;
        this.lfoGain = null;
      }

      init() {
        this.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        this.analyser = this.audioCtx.createAnalyser();
        this.analyser.fftSize = 64;

        this.gainNode = this.audioCtx.createGain();
        this.gainNode.gain.setValueAtTime(0.0, this.audioCtx.currentTime);

        this.filterNode = this.audioCtx.createBiquadFilter();
        this.filterNode.type = 'lowpass';
        this.filterNode.frequency.setValueAtTime(this.type === 'engine' ? 180 : 320, this.audioCtx.currentTime);
        this.filterNode.Q.setValueAtTime(1.5, this.audioCtx.currentTime);

        const baseFreq = this.type === 'engine' ? 28 : 22;
        const numOscs = this.type === 'engine' ? 4 : 5;

        for (let i = 0; i < numOscs; i++) {
          const osc = this.audioCtx.createOscillator();
          osc.type = i % 2 === 0 ? 'sawtooth' : 'triangle';

          const multiplier = i === 0 ? 1 : (i === 1 ? 1.5 : (i === 2 ? 2.0 : 3.5));
          osc.frequency.setValueAtTime(baseFreq * multiplier, this.audioCtx.currentTime);
          osc.detune.setValueAtTime((Math.random() - 0.5) * 15, this.audioCtx.currentTime);

          const oscGain = this.audioCtx.createGain();
          oscGain.gain.setValueAtTime(i === 0 ? 0.35 : 0.15, this.audioCtx.currentTime);

          osc.connect(oscGain);
          oscGain.connect(this.filterNode);
          this.oscillators.push(osc);
        }

        const bufferSize = this.audioCtx.sampleRate * 2;
        const noiseBuffer = this.audioCtx.createBuffer(1, bufferSize, this.audioCtx.sampleRate);
        const output = noiseBuffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          output[i] = Math.random() * 2 - 1;
        }

        this.noiseNode = this.audioCtx.createBufferSource();
        this.noiseNode.buffer = noiseBuffer;
        this.noiseNode.loop = true;

        this.noiseFilter = this.audioCtx.createBiquadFilter();
        this.noiseFilter.type = 'bandpass';
        this.noiseFilter.frequency.setValueAtTime(this.type === 'engine' ? 120 : 160, this.audioCtx.currentTime);
        this.noiseFilter.Q.setValueAtTime(1.0, this.audioCtx.currentTime);

        const noiseGain = this.audioCtx.createGain();
        noiseGain.gain.setValueAtTime(this.type === 'engine' ? 0.04 : 0.16, this.audioCtx.currentTime);

        this.noiseNode.connect(this.noiseFilter);
        this.noiseFilter.connect(noiseGain);
        noiseGain.connect(this.gainNode);

        this.lfo = this.audioCtx.createOscillator();
        this.lfo.type = 'sine';
        this.lfo.frequency.setValueAtTime(this.type === 'engine' ? 14 : 9, this.audioCtx.currentTime);

        this.lfoGain = this.audioCtx.createGain();
        this.lfoGain.gain.setValueAtTime(0.2, this.audioCtx.currentTime);

        this.lfo.connect(this.lfoGain);
        this.lfoGain.connect(this.gainNode.gain);

        this.filterNode.connect(this.gainNode);
        this.gainNode.connect(this.analyser);
        this.analyser.connect(this.audioCtx.destination);
      }

      play() {
        if (this.isPlaying) return;
        if (!this.audioCtx) this.init();
        if (this.audioCtx.state === 'suspended') this.audioCtx.resume();

        this.oscillators.forEach(osc => osc.start());
        this.noiseNode.start();
        this.lfo.start();

        this.gainNode.gain.cancelScheduledValues(this.audioCtx.currentTime);
        this.gainNode.gain.setValueAtTime(0.0, this.audioCtx.currentTime);
        this.gainNode.gain.linearRampToValueAtTime(this.type === 'engine' ? 0.70 : 0.80, this.audioCtx.currentTime + 0.15);

        this.isPlaying = true;
      }

      stop() {
        if (!this.isPlaying) return;

        this.gainNode.gain.cancelScheduledValues(this.audioCtx.currentTime);
        this.gainNode.gain.linearRampToValueAtTime(0.0, this.audioCtx.currentTime + 0.2);

        const oscsToStop = this.oscillators;
        const noiseToStop = this.noiseNode;
        const lfoToStop = this.lfo;

        setTimeout(() => {
          oscsToStop.forEach(osc => { try { osc.stop(); } catch (e) { } });
          try { noiseToStop.stop(); } catch (e) { }
          try { lfoToStop.stop(); } catch (e) { }
        }, 250);

        this.oscillators = [];
        this.noiseNode = null;
        this.lfo = null;
        this.audioCtx = null;
        this.isPlaying = false;
      }
    }

    const engineSound = new EngineSoundGenerator('engine');
    const exhaustSound = new EngineSoundGenerator('exhaust');

    function setupAudioPlayer(playerId, generator) {
      const playerEl = document.getElementById(playerId);
      if (!playerEl) return;

      const playBtn = playerEl.querySelector('.play-btn');
      const playIcon = playBtn.querySelector('.play-icon');
      const pauseIcon = playBtn.querySelector('.pause-icon');
      const canvas = playerEl.querySelector('.wave-visualizer');
      const ctx = canvas.getContext('2d');

      let phase = 0;
      let isHovered = false;
      let smoothHover = 0;
      let lastFrameTime = performance.now();

      function renderWave() {
        requestAnimationFrame(renderWave);

        const now = performance.now();
        const dt = Math.min((now - lastFrameTime) / 1000, 0.1);
        lastFrameTime = now;

        // Smooth hover transition with exponential decay
        const hoverEase = 1 - Math.exp(-8 * dt);
        smoothHover += ((isHovered ? 1.0 : 0.0) - smoothHover) * hoverEase;

        let amplitude = 1.5; // Idle ambient amplitude
        let phaseSpeed = 0.04; // Idle speed

        const colors = [
          canvas.dataset.color1 || 'rgba(36, 158, 160, 0.95)',
          canvas.dataset.color2 || 'rgba(30, 200, 203, 0.70)',
          canvas.dataset.color3 || 'rgba(36, 158, 160, 0.45)',
          canvas.dataset.color4 || 'rgba(255, 255, 255, 0.25)',
          canvas.dataset.color5 || 'rgba(36, 158, 160, 0.12)'
        ];

        if (generator.isPlaying && generator.analyser) {
          const bufferLength = generator.analyser.frequencyBinCount;
          const dataArray = new Uint8Array(bufferLength);
          generator.analyser.getByteFrequencyData(dataArray);

          let sum = 0;
          for (let i = 0; i < bufferLength; i++) {
            sum += dataArray[i];
          }
          const average = sum / bufferLength;

          // Compute amplitude: scale with audio data (range 2.5px to 12.5px)
          amplitude = (average / 255) * 10 + 2.5;
          amplitude *= (1.0 + smoothHover * 0.28); // Maximum amplitude capped at ~16px to prevent clipping

          // Phase speed matches LFO frequency (accelerates on rev hover)
          phaseSpeed = generator.lfo ? (generator.lfo.frequency.value * 0.012) : 0.15;
        } else {
          // Subtle breathing when paused, speeds up slightly on hover to acknowledge pointer
          amplitude = 1.6 + smoothHover * 0.9;
          phaseSpeed = 0.03 + smoothHover * 0.03;
        }

        ctx.clearRect(0, 0, canvas.width, canvas.height);
        phase += phaseSpeed;

        const numWaves = 5;
        for (let l = 0; l < numWaves; l++) {
          ctx.beginPath();

          // Apply a glowing neon filter when active
          if (generator.isPlaying) {
            ctx.shadowBlur = (12 - l * 2) * (1.0 + smoothHover * 0.4);
            ctx.shadowColor = canvas.dataset.accent || '#249EA0';
          } else {
            ctx.shadowBlur = 0;
          }

          // Foreground lines are thicker, background are thinner
          ctx.lineWidth = l === 0 ? 2.2 : (l === 1 ? 1.4 : (l === 2 ? 0.9 : 0.5));
          ctx.strokeStyle = colors[l % colors.length];

          // Offset the phase of each wave layer to create a sliding 3D effect
          const wavePhase = phase + l * (Math.PI / 2.2);

          // Frequencies adjust based on layer and hover state (making them look tighter and more aggressive on hover)
          const baseFreq = (0.038 - l * 0.006) * (1.0 + smoothHover * 0.25);

          for (let x = 0; x < canvas.width; x++) {
            // Taper waves at left and right edges with a sine envelope
            const envelope = Math.sin((x / canvas.width) * Math.PI);

            // Normalized compound wave components (coefficients sum to 1.0, ensuring no boundary clipping)
            const primarySine = Math.sin(x * baseFreq + wavePhase) * 0.65;
            const secondaryHarmonic = Math.sin(x * (baseFreq * 2.2) - wavePhase * 1.3) * (0.22 + smoothHover * 0.08);
            const tertiaryJitter = Math.sin(x * (baseFreq * 4.6) + wavePhase * 2.5) * (0.05 + smoothHover * 0.05);

            const waveY = (primarySine + secondaryHarmonic + tertiaryJitter) * amplitude * envelope;
            const y = canvas.height / 2 + waveY;

            if (x === 0) {
              ctx.moveTo(x, y);
            } else {
              ctx.lineTo(x, y);
            }
          }
          ctx.stroke();
        }
      }

      // Initialize the rendering loop
      renderWave();

      playBtn.addEventListener('click', () => {
        if (generator.isPlaying) {
          generator.stop();
          playerEl.classList.remove('playing');
          playIcon.style.display = 'block';
          pauseIcon.style.display = 'none';

          // Smoothly restore background music volume if playing
          if (window.ambientMusic && window.ambientMusic.isPlaying) {
            window.ambientMusic.fadeTo(0.32, 1.0);
          }
          if (window.partyMusic && window.partyMusic.isPlaying) {
            window.partyMusic.fadeTo(0.42, 1.0);
          }
        } else {
          if (generator === engineSound && exhaustSound.isPlaying) {
            document.getElementById('exhaust-player').querySelector('.play-btn').click();
          } else if (generator === exhaustSound && engineSound.isPlaying) {
            document.getElementById('engine-player').querySelector('.play-btn').click();
          }

          generator.play();
          playerEl.classList.add('playing');
          playIcon.style.display = 'none';
          pauseIcon.style.display = 'block';

          // Duck background music volume during active engine sound previews to prevent mud
          if (window.ambientMusic && window.ambientMusic.isPlaying) {
            window.ambientMusic.fadeTo(0.04, 0.8);
          }
          if (window.partyMusic && window.partyMusic.isPlaying) {
            window.partyMusic.fadeTo(0.05, 0.8);
          }
        }
      });

      playerEl.addEventListener('mouseenter', () => {
        isHovered = true;
        if (generator.isPlaying && generator.audioCtx) {
          const time = generator.audioCtx.currentTime;
          const baseFreq = generator.type === 'engine' ? 28 : 22;
          generator.oscillators.forEach((osc, idx) => {
            const multiplier = idx === 0 ? 1 : (idx === 1 ? 1.5 : (idx === 2 ? 2.0 : 3.5));
            osc.frequency.setValueAtTime(osc.frequency.value, time);
            osc.frequency.exponentialRampToValueAtTime(baseFreq * multiplier * 2.2, time + 0.5);
          });
          generator.lfo.frequency.setValueAtTime(generator.lfo.frequency.value, time);
          generator.lfo.frequency.linearRampToValueAtTime(generator.type === 'engine' ? 32 : 22, time + 0.5);
        }
      });

      playerEl.addEventListener('mouseleave', () => {
        isHovered = false;
        if (generator.isPlaying && generator.audioCtx) {
          const time = generator.audioCtx.currentTime;
          const baseFreq = generator.type === 'engine' ? 28 : 22;
          generator.oscillators.forEach((osc, idx) => {
            const multiplier = idx === 0 ? 1 : (idx === 1 ? 1.5 : (idx === 2 ? 2.0 : 3.5));
            osc.frequency.setValueAtTime(osc.frequency.value, time);
            osc.frequency.exponentialRampToValueAtTime(baseFreq * multiplier, time + 0.7);
          });
          generator.lfo.frequency.setValueAtTime(generator.lfo.frequency.value, time);
          generator.lfo.frequency.linearRampToValueAtTime(generator.type === 'engine' ? 14 : 9, time + 0.7);
        }
      });
    }

